---
import MainLayout from "@/layouts/MainLayout.astro";
import type { GetStaticPaths } from "astro";
import Image from "astro/components/Image.astro";
import { getCollection, render } from "astro:content";

export const getStaticPaths = (async () => {
  const articles = await getCollection("articles");
  return articles
    .filter((article) => !article.data.draft)
    .map((article) => ({
      params: { slug: article.id },
      props: { article },
    }));
}) satisfies GetStaticPaths;

const { article } = Astro.props;
const { title, author, cover, coverAlt, pubDate, description } = article.data;
const { Content } = await render(article);
---

<MainLayout title={`Artículo | ${title}`}>
  <article class="article-wrapper">
    <button class="btn-back" onclick="history.back()"
      >&larr; Volver atrás</button
    >
    <div class="article-header">
      <h1>{title}</h1>
      <div class="article-header-details">
        <p>{author}</p>
        <time
          >{
            pubDate.toLocaleDateString("es-ES", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }</time
        >
      </div>
      <h3>{description}</h3>
    </div>
    <div class="hero-wrapper">
      <Image
        class="article-hero"
        src={cover}
        alt={coverAlt}
        width={780}
        height={280}
      />
    </div>
    <div class="md-content">
      <Content />
    </div>
  </article>
</MainLayout>

<style>
  .article-wrapper {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s ease;
    margin-bottom: 1.5rem;
  }

  .btn-back:hover {
    opacity: 1;
  }

  .article-header {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.15;
    color: var(--color-text);
    margin: 0;
  }

  .article-header-details {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-header-details p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .article-header-details p::after {
    content: "·";
    margin-left: 0.5rem;
  }

  time {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h3 {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    font-weight: 400;
    line-height: 1.5;
    margin: 0;
    border-left: 3px solid var(--color-primary);
    padding-left: 1rem;
  }

  .hero-wrapper {
    margin: 2rem 0 2.5rem;
  }

  .article-hero {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: center;
    display: block;
    border-radius: 12px;
  }

  @media (min-width: 768px) {
    .article-wrapper {
      padding: 4rem 3rem 6rem;
    }
  }

  @media (min-width: 1024px) {
    .article-wrapper {
      padding: 3rem 0 7rem;
    }
    .article-hero {
      aspect-ratio: 21 / 9;
    }
  }
</style>
