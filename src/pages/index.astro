---
import ArticleCard from "@/components/ArticleCard.astro";
import ArticleCarousel from "@/components/ArticleCarousel.astro";
import HeroBanner from "@/components/HeroBanner.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles");
const sorted = articles
  .filter((art) => !art.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const highlightArts = sorted.slice(0, 2);
const otherArts = sorted.slice(2, 6);
---

<MainLayout title="Home">
  <HeroBanner />
  <ArticleCarousel carouselTitle="Últimos Artículos">
    <ArticleCard
      horizontal
      position="right"
      id={highlightArts[0].id}
      article={highlightArts[0].data}
    />
    <ArticleCard id={highlightArts[1].id} article={highlightArts[1].data} />
  </ArticleCarousel>
  <ArticleCarousel carouselTitle="Otros Artículos">
    {otherArts.map(({ id, data }) => <ArticleCard id={id} article={data} />)}
  </ArticleCarousel>
</MainLayout>
