---
import Logo from "./Logo.astro";
const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-content">
    <div class="footer-logo-wrapper">
      <Logo className="footer-logo" />
    </div>
    <small>&copy; <span>{year}</span> Todos los derechos reservados</small>
  </div>
</footer>

<style>
  footer {
    background-color: var(--color-surface);
    border-top: 1px solid var(--color-border);
    padding: 1rem 0;
    margin-top: auto;
  }

  .footer-content {
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .footer-logo-wrapper {
    width: 28px;
    height: 28px;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
    flex-shrink: 0;
  }

  .footer-logo-wrapper:hover {
    color: var(--color-primary);
  }

  .footer-logo {
    width: 100%;
    height: 100%;
  }

  small {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    text-align: right;
  }

  small span {
    font-weight: 600;
    color: var(--color-text);
  }

  @media (min-width: 768px) {
    footer {
      padding: 2rem 0;
    }

    .footer-logo-wrapper {
      width: 40px;
      height: 40px;
    }

    small {
      font-size: 0.95rem;
    }
  }
</style>
