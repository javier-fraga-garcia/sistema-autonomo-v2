---
import type { InferEntrySchema } from "astro:content";
import { Image } from "astro:assets";

interface Props {
  id: string;
  article: InferEntrySchema<"articles">;
  horizontal?: boolean;
  position?: string;
}

const { horizontal = false, position = "left", article, id } = Astro.props;
const { title, pubDate, description, cover, coverAlt } = article;
---

<article class:list={["card", { horizontal }, position]}>
  <div class="card-image">
    <Image src={cover} alt={coverAlt} />
  </div>
  <div class="card-text">
    <h2>{title}</h2>
    <span><time>{pubDate.toLocaleDateString()}</time></span>
    <p>
      {description}
    </p>
    <a class="read-more" href=`/articles/${id}`>Leer &rarr;</a>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    height: 100%;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease,
      border-color 0.2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border-color: var(--color-primary);
  }
  .card-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .card:hover .card-image img {
    transform: scale(1.05);
  }
  .card-text {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  h2 {
    font-size: 1.25rem;
    margin-top: 0;
    margin-bottom: 0.75rem;
    color: var(--color-text);
    line-height: 1.3;
  }
  time {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
  }
  p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    flex: 1;
  }
  .read-more {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: color 0.2s ease;
    margin-top: auto;
  }
  .read-more:hover {
    color: var(--color-accent);
    text-decoration: none;
  }
  @media (min-width: 768px) {
    .card.horizontal {
      flex-direction: row;
      grid-column: 1 / -2;
    }
    .card.horizontal.right {
      flex-direction: row-reverse;
    }
    .card.horizontal .card-image {
      width: 45%;
      aspect-ratio: auto;
      flex-shrink: 0;
    }
    .card.horizontal .card-text {
      width: 55%;
      padding: 2.5rem;
      justify-content: center;
    }
    .card.horizontal h2 {
      font-size: 1.5rem;
    }
  }
</style>
